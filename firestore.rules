rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
    }

    match /swipes/{swipeId} {
      allow read, create: if isAuthenticated() && request.resource.data.fromUserId == request.auth.uid;
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.users;
      allow create, update: if isAuthenticated();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated();
    }
    
    match /reservations/{reservationId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.users;
      allow create, update: if isAuthenticated() && request.auth.uid in request.resource.data.users;
    }
  }
}
